# .env — Copy this to .env and fill in your values
# DO NOT commit .env to version control

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/trading_journal?retryWrites=true&w=majority

# JWT Secret — MUST be at least 32 characters, change this!
JWT_SECRET=change-this-to-a-long-random-secret-key-minimum-32-chars

# CORS — set to your frontend domain in production
ALLOWED_ORIGINS=http://localhost:4200
